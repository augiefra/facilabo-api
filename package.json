{
  "name": "facilabo-api",
  "version": "1.0.0",
  "description": "API for FacilAbo TV schedule scraping",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vercel dev",
    "typecheck": "tsc --noEmit",
    "test:update-notices": "node --experimental-strip-types --test lib/update-notice-visibility.test.ts",
    "check:client-contracts": "node scripts/check-client-contracts.mjs",
    "check": "npm run typecheck && npm run test:update-notices && npm run check:client-contracts"
  },
  "dependencies": {
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vercel/node": "^3.0.0",
    "typescript": "^5.3.0"
  }
}
